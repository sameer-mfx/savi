<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ir_cron_update_amc_validity" model="ir.cron">
            <field name="name">Update AMC Validity</field>
            <field name="model_id" ref="amc_mfx.model_amc_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_update_amc_validity()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_amc_billing_reminders" model="ir.cron">
            <field name="name">AMC Billing Reminders</field>
            <field name="model_id" ref="amc_mfx.model_amc_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_billing_reminders()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>