<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- This action will be called when AMC Service menu item was clicked -->
    <record id="action_amc_services" model="ir.actions.act_window">
        <field name="name">AMC Services</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">amc.services</field>
        <field name="view_mode">tree,form</field>
        <field name="binding_view_types">tree</field>
        <field name="context">{'search_default_group_by_product_id': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Click on New to create a new AMC Service
            </p>
        </field>
    </record>

    <!-- AMC Services tree view -->
    <record id="amc_services_tree" model="ir.ui.view">
        <field name="name">amc.services.tree</field>
        <field name="model">amc.services</field>
        <field name="arch" type="xml">
            <tree string="AMC Services" sample="1">
                <field name="product_id"/>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="amc_services_form" model="ir.ui.view">
        <field name="name">amc.services.form</field>
        <field name="model">amc.services</field>
        <field name="arch" type="xml">
            <form string="AMC Service">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="name"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- AMC Services search view -->
    <record id="view_amc_services_search" model="ir.ui.view">
        <field name="name">amc.services.search.view</field>
        <field name="model">amc.services</field>
        <field name="arch" type="xml">
            <search string="Product">
                <group expand="0" string="Group By">
                    <filter name="group_by_product_id" string="Product" domain="[]"  context="{'group_by':'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <menuitem id="menu_amc_services_root"
              name="Services"
              parent="amc_mfx.menu_amc_management"
              sequence="3"/>

    <menuitem id="menu_amc_services"
              name="Services"
              action="action_amc_services"
              parent="menu_amc_services_root"
              sequence="1"/>

</odoo>