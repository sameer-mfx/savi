<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Record rule: respect AMC company rule -->
    <record id="amc_replacement_rule_company" model="ir.rule">
        <field name="name">AMC Replacement: Company Rule</field>
        <field name="model_id" ref="model_amc_replacement"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="amc_expense_rule_company" model="ir.rule">
        <field name="name">AMC Expense: Company Rule</field>
        <field name="model_id" ref="model_amc_expense"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Replacement Form -->
    <record id="amc_replacement_form_view" model="ir.ui.view">
        <field name="name">amc.replacement.form</field>
        <field name="model">amc.replacement</field>
        <field name="arch" type="xml">
            <form string="AMC Replacement">
                <header>
                    <button name="action_submit" type="object" string="Submit for Approval" class="oe_highlight"
                            invisible="state != 'draft' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_user"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight"
                            invisible="state != 'to_approve' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <button name="action_reject" type="object" string="Reject" class="btn btn-warning"
                            invisible="state != 'to_approve' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <button name="action_issue" type="object" string="Issue to Customer" class="oe_highlight"
                            invisible="state != 'approved' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_user"/>
                    <button name="action_done" type="object" string="Mark Done" class="oe_highlight"
                            invisible="state != 'issued' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_user"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn btn-danger"
                            invisible="state in ('done', 'cancel') or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <button name="action_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('rejected', 'cancel') or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved,issued,done"/>
                </header>
                <sheet>
                    <field name="amc_is_locked" invisible="1"/>
                    <field name="amc_is_expired" invisible="1"/>
                    <field name="amc_state" invisible="1"/>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="alert alert-warning" role="alert" invisible="state != 'rejected'">
                        <strong>Rejected.</strong> <field name="rejection_reason" nolabel="1" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="amc_id" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="visit_id" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                        </group>
                        <group>
                            <field name="issue_date" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="approved_by" readonly="1" invisible="not approved_by"/>
                            <field name="approved_date" readonly="1" invisible="not approved_date"/>
                        </group>
                    </group>
                    <group string="Faulty Product (from Customer)">
                        <group>
                            <field name="faulty_product_id" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="faulty_lot_id" readonly="state != 'draft' or amc_state != 'approved'"/>
                        </group>
                    </group>
                    <group string="Issued Product (to Customer)">
                        <group>
                            <field name="issued_product_id" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="issued_lot_id" readonly="state != 'draft' or amc_state != 'approved'"/>
                        </group>
                        <group>
                            <field name="quantity" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="unit_cost" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="total_cost"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" nolabel="1" placeholder="Remarks..." readonly="state != 'draft' or amc_state != 'approved'"/>
                    </group>
                    <group invisible="state != 'to_approve'" groups="amc_mfx.amc_group_manager">
                        <field name="rejection_reason" placeholder="Reason (required if rejecting)..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Replacement Tree -->
    <record id="amc_replacement_tree_view" model="ir.ui.view">
        <field name="name">amc.replacement.tree</field>
        <field name="model">amc.replacement</field>
        <field name="arch" type="xml">
            <tree string="AMC Replacements" decoration-muted="state in ('cancel','rejected')" decoration-success="state=='done'">
                <field name="issue_date"/>
                <field name="amc_id"/>
                <field name="partner_id"/>
                <field name="visit_id"/>
                <field name="faulty_product_id"/>
                <field name="issued_product_id"/>
                <field name="quantity"/>
                <field name="total_cost" sum="Total Cost"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-warning="state in ('to_approve','issued')"
                       decoration-success="state in ('approved','done')"
                       decoration-danger="state in ('cancel','rejected')"/>
            </tree>
        </field>
    </record>

    <!-- Expense Form -->
    <record id="amc_expense_form_view" model="ir.ui.view">
        <field name="name">amc.expense.form</field>
        <field name="model">amc.expense</field>
        <field name="arch" type="xml">
            <form string="AMC Expense">
                <header>
                    <button name="action_submit" type="object" string="Submit for Approval" class="oe_highlight"
                            invisible="state != 'draft' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_user"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight"
                            invisible="state != 'to_approve' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <button name="action_reject" type="object" string="Reject" class="btn btn-warning"
                            invisible="state != 'to_approve' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight"
                            invisible="state != 'approved' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_user"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn btn-danger"
                            invisible="state == 'cancel' or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <button name="action_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('rejected','cancel','confirmed') or amc_state != 'approved'"
                            groups="amc_mfx.amc_group_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved,confirmed"/>
                </header>
                <sheet>
                    <field name="amc_is_locked" invisible="1"/>
                    <field name="amc_state" invisible="1"/>
                    <div class="alert alert-warning" role="alert" invisible="state != 'rejected'">
                        <strong>Rejected.</strong> <field name="rejection_reason" nolabel="1" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="amc_id" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="visit_id" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="expense_type" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="replacement_id" invisible="expense_type != 'replacement'" readonly="state != 'draft' or amc_state != 'approved'"/>
                        </group>
                        <group>
                            <field name="expense_date" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="engineer_id" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="amount" readonly="state != 'draft' or amc_state != 'approved'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="approved_by" readonly="1" invisible="not approved_by"/>
                            <field name="approved_date" readonly="1" invisible="not approved_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" required="1" readonly="state != 'draft' or amc_state != 'approved'"/>
                        <field name="note" placeholder="Remarks..." readonly="state != 'draft' or amc_state != 'approved'"/>
                    </group>
                    <group invisible="state != 'to_approve'" groups="amc_mfx.amc_group_manager">
                        <field name="rejection_reason" placeholder="Reason (required if rejecting)..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Expense Tree -->
    <record id="amc_expense_tree_view" model="ir.ui.view">
        <field name="name">amc.expense.tree</field>
        <field name="model">amc.expense</field>
        <field name="arch" type="xml">
            <tree string="AMC Expenses" decoration-muted="state in ('cancel','rejected')" decoration-success="state in ('approved','confirmed')">
                <field name="expense_date"/>
                <field name="amc_id"/>
                <field name="partner_id"/>
                <field name="visit_id"/>
                <field name="expense_type"/>
                <field name="description"/>
                <field name="engineer_id"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-warning="state=='to_approve'"
                       decoration-success="state in ('approved','confirmed')"
                       decoration-danger="state in ('cancel','rejected')"/>
            </tree>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_amc_replacement" model="ir.actions.act_window">
        <field name="name">AMC Replacements</field>
        <field name="res_model">amc.replacement</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_amc_expense" model="ir.actions.act_window">
        <field name="name">AMC Expenses</field>
        <field name="res_model">amc.expense</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_amc_replacement"
              name="Replacements"
              parent="amc_mfx.menu_amc_management"
              action="action_amc_replacement"
              groups="amc_mfx.amc_group_user"
              sequence="3"/>

    <menuitem id="menu_amc_expense"
              name="Expenses"
              parent="amc_mfx.menu_amc_management"
              action="action_amc_expense"
              groups="amc_mfx.amc_group_user"
              sequence="4"/>

    <!-- Inherit AMC Order form to add Replacements, Expenses, and P&L -->
    <record id="view_amc_order_form_inherit_pnl" model="ir.ui.view">
        <field name="name">amc.order.form.inherit.pnl</field>
        <field name="model">amc.order</field>
        <field name="inherit_id" ref="amc_mfx.amc_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_replacements" type="object" class="oe_stat_button" icon="fa-exchange">
                    <field name="replacement_count" widget="statinfo" string="Replacements"/>
                </button>
                <button name="action_view_expenses" type="object" class="oe_stat_button" icon="fa-money">
                    <field name="expense_count" widget="statinfo" string="Expenses"/>
                </button>
                <button name="action_view_pending_approvals" type="object" class="oe_stat_button" icon="fa-clock-o"
                        invisible="pending_replacement_count + pending_expense_count == 0"
                        groups="amc_mfx.amc_group_manager">
                    <div class="o_stat_info">
                        <span class="o_stat_value text-warning">
                            <field name="pending_replacement_count"/> / <field name="pending_expense_count"/>
                        </span>
                        <span class="o_stat_text">Pending Approvals</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Replacements">
                    <div class="alert alert-info" role="alert">
                        Replacements are created by technicians from the linked Site Visit. Managers approve/reject from here or from the replacement form.
                    </div>
                    <field name="replacement_ids" readonly="1">
                        <tree decoration-muted="state in ('cancel','rejected')" decoration-success="state=='done'">
                            <field name="issue_date"/>
                            <field name="visit_id"/>
                            <field name="faulty_product_id"/>
                            <field name="issued_product_id"/>
                            <field name="quantity"/>
                            <field name="unit_cost"/>
                            <field name="total_cost"/>
                            <field name="approved_by" optional="hide"/>
                            <field name="state" widget="badge"
                                   decoration-info="state=='draft'"
                                   decoration-warning="state in ('to_approve','issued')"
                                   decoration-success="state in ('approved','done')"
                                   decoration-danger="state in ('cancel','rejected')"/>
                            <field name="currency_id" column_invisible="1"/>
                        </tree>
                    </field>
                </page>
                <page string="Expenses">
                    <div class="alert alert-info" role="alert">
                        Expenses are raised by technicians against a Site Visit. Managers approve/reject from here or from the expense form.
                    </div>
                    <field name="expense_ids" readonly="1">
                        <tree decoration-muted="state in ('cancel','rejected')" decoration-success="state in ('approved','confirmed')">
                            <field name="expense_date"/>
                            <field name="visit_id"/>
                            <field name="expense_type"/>
                            <field name="description"/>
                            <field name="engineer_id"/>
                            <field name="amount"/>
                            <field name="approved_by" optional="hide"/>
                            <field name="state" widget="badge"
                                   decoration-info="state=='draft'"
                                   decoration-warning="state=='to_approve'"
                                   decoration-success="state in ('approved','confirmed')"
                                   decoration-danger="state in ('cancel','rejected')"/>
                            <field name="currency_id" column_invisible="1"/>
                        </tree>
                    </field>
                </page>
                <page string="P&amp;L" groups="amc_mfx.amc_group_manager">
                    <group>
                        <group string="Revenue">
                            <field name="total_revenue" widget="monetary"/>
                        </group>
                        <group string="Costs">
                            <field name="total_replacement_cost" widget="monetary"/>
                            <field name="total_expense_cost" widget="monetary"/>
                            <field name="total_cost" widget="monetary"/>
                        </group>
                    </group>
                    <group>
                        <group string="Profit / Loss">
                            <field name="profit_amount" widget="monetary"/>
                            <field name="profit_margin" widget="percentage"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Add P&L columns to AMC order tree (visible to managers) -->
    <record id="view_amc_order_tree_inherit_pnl" model="ir.ui.view">
        <field name="name">amc.order.tree.inherit.pnl</field>
        <field name="model">amc.order</field>
        <field name="inherit_id" ref="amc_mfx.amc_order_tree"/>
        <field name="arch" type="xml">
            <field name="amount_total" position="after">
                <field name="total_cost" optional="hide" widget="monetary" groups="amc_mfx.amc_group_manager"/>
                <field name="profit_amount" optional="hide" widget="monetary" groups="amc_mfx.amc_group_manager"/>
                <field name="profit_margin" optional="hide" widget="percentage" groups="amc_mfx.amc_group_manager"/>
            </field>
        </field>
    </record>

</odoo>
