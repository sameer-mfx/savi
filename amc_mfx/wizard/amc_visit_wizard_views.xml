<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="amc_visit_wizard_form_view" model="ir.ui.view">
        <field name="name">amc.visit.wizard.form</field>
        <field name="model">amc.visit.wizard</field>
        <field name="arch" type="xml">
            <form string="Create AMC Visit">
                <group>
                    <group>
                        <field name="amc_order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="assigned_to_ids" widget="many2many_tags"/>
                        <field name="visit_date"/>
                    </group>
                </group>
                <separator string="Remarks / Instructions for Engineer"/>
                <field name="remarks" placeholder="Enter any instructions or message for the engineer visiting the site..."/>
                <separator string="Select AMC Line Items for this Visit"/>
                <field name="wizard_line_ids" nolabel="1">
                    <tree editable="bottom" create="0" delete="0">
                        <field name="selected" widget="boolean_toggle"/>
                        <field name="product_id" readonly="1"/>
                        <field name="service_id" readonly="1"/>
                        <field name="description" readonly="1"/>
                        <field name="location" readonly="1"/>
                        <field name="lot_id" string="Serial Number" readonly="1" force_save="1"/>
                        <field name="amc_line_id" column_invisible="1"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_create_visit" string="Create Visit" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_amc_visit_wizard" model="ir.actions.act_window">
        <field name="name">Create AMC Visit</field>
        <field name="res_model">amc.visit.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
