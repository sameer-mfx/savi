<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_sale_order_form_custom_whatsapp" model="ir.ui.view">
        <field name="name">sale.order.form.custom.whatsapp</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@id='send_by_email']" position="after">
                <button name="action_send_quotation_whatsapp" type="object" icon="fa-whatsapp" string="Reminder" data-hotkey="w" invisible="state != 'sent'" context="{'send_sale_reminder_whatsapp': True}"/>
            </xpath>
        </field>
    </record>

</odoo>