<odoo>
    <data>
        <record id="mail_template_sale_quotation_any_state" model="mail.template">
            <field name="name">Sales: Quotation (Any State)</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">{{ object.company_id.name }} {{ ctx.get('proforma') and 'Proforma' or 'Quotation' }} (Ref {{ object.name or 'n/a' }})</field>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="description">Send quotation email regardless of the Sales Order state</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        <t t-if="object.partner_id.name">Hello <span style="font-weight: bold;" t-out="object.partner_id.name"/>,</t>
                        <t t-else="">Hello,</t>
                        <br/><br/>
                        Your quotation <span style="font-weight: bold;" t-out="object.name or ''"/>
                        <t t-if="object.origin">
                            (reference: <t t-out="object.origin or ''"></t>)
                        </t>
                        amounting to <span style="font-weight: bold;" t-out="format_amount(object.amount_total, object.currency_id) or ''"></span> is ready for your review.
                        <br/><br/>
                        Do not hesitate to contact us if you have any questions.
                        <t t-if="not is_html_empty(object.user_id.signature)">
                            <br/><br/>
                            <t t-out="object.user_id.signature or ''"/>
                        </t>
                        <br/><br/>
                    </p>
                </div>
            </field>
            <field name="report_template_ids" eval="[(6, 0, [ref('custom_crm_mfx.action_report_saleorder_custom_quotation')])]"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>