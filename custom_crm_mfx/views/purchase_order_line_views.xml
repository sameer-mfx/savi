<odoo>

    <record id="purchase_order_form_custom" model="ir.ui.view">
        <field name="name">purchase.order.form.custom</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group[2]" position="inside">
                <field name="tandc_id" domain="[('type', '=', 'purchase')]" context="{'default_type': 'purchase'}"/>
                <field name="sale_order_ids" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="partner_email" widget="email"/>
                <field name="partner_mobile" widget="phone"/>
            </xpath>
        </field>
    </record>

    <record id="action_def_tandc_purchase" model="ir.actions.act_window">
        <field name="name">Terms and Conditions</field>
        <field name="res_model">def.tandc</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'from_purchase': True}</field>
        <field name="domain">[('type', '=', 'purchase')]</field>
    </record>

    <menuitem id="menu_def_tandc_purchase" name="Terms and Conditions" parent="purchase.menu_purchase_config" action="custom_crm_mfx.action_def_tandc_purchase" sequence="10"/>

</odoo>
