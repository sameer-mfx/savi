<odoo>
    <data>

        <record id="email_template_sale_quotation_reminder" model="mail.template">
            <field name="name">Sales: Quotation Reminder</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">Reminder: Quotation {{ object.name }} is awaiting your review</field>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{object.email}}</field>
            <field name="description">Reminder for Sales Quotation</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        <p>Dear <t t-out="object.partner_id.name"></t>,</p>

                        <p>I hope this message finds you well.</p>

                        <p>This is a gentle reminder regarding the quotation <strong><t t-out="object.name"/></strong> we shared with you on <strong><t t-out="format_date(object.date_order, 'dd MMM yyyy')"/></strong>.</p>

                        <p>We wanted to ensure you’ve had the chance to review it. If you have any questions or would like any changes, please don’t hesitate to contact us.</p>

                        <p>We look forward to your response and hope to move ahead together.</p>

                        <p>Best regards,<br/><t t-out="object.user_id.name"></t><br/><t t-out="object.company_id.name or 'Savi Vision Pvt Ltd'"></t></p>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
            <field name="report_template_ids" eval="[(4, ref('sale.action_report_saleorder'))]"/>
        </record>

    </data>
</odoo>