<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_company_form_inherit_time" model="ir.ui.view">
        <field name="name">res.company.form.worktimes</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']/group/group[@name='social_media']" position="before">
                <group string="Work Timings" name="work_timings">
                    <field name="work_start_time" widget="float_time"/>
                    <field name="work_end_time" widget="float_time"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>