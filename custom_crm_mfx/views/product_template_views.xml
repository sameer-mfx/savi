<odoo>
    <record id="view_product_template_form_inherit_make" model="ir.ui.view">
        <field name="name">product.template.form.inherit.make</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='detailed_type']" position="after">
                <field name="make"/>
                <field name="website_url" widget="url"/>
            </xpath>
        </field>
    </record>

    <!-- Add Maximum Retail Price below Cost field -->
    <record id="view_product_template_form_inherit_mrp" model="ir.ui.view">
        <field name="name">product.template.form.inherit.mrp</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <label for="maximum_retail_price"/>
                <div name="maximum_retail_price_div" class="o_row">
                    <field name="maximum_retail_price" class="oe_inline"
                           widget="monetary"
                           options="{'currency_field': 'currency_id', 'field_digits': True}"/>
                </div>
                <field name="last_salesprice_update" readonly="1"/>
                <field name="last_cost_update" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>