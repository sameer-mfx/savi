<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="mfx_view_move_form" model="ir.ui.view">
		<field name="name">account.move.form</field>
		<field name="model">account.move</field>
		<field name="inherit_id" ref="account.view_move_form"/>
		<field name="arch" type="xml">
			<xpath expr="//button[@name='action_post']" position="attributes">
				<attribute name="groups">custom_crm_mfx.group_confirm_accounting_entry</attribute>
			</xpath>
			<xpath expr="//button[@name='action_post'][2]" position="attributes">
				<attribute name="groups">custom_crm_mfx.group_confirm_accounting_entry</attribute>
			</xpath>
		</field>
	</record>

    <record id="mfx_purchase_order_form" model="ir.ui.view">
		<field name="name">purchase.order.form</field>
		<field name="model">purchase.order</field>
		<field name="inherit_id" ref="purchase.purchase_order_form"/>
		<field name="arch" type="xml">
			<xpath expr="//button[@name='action_create_invoice']" position="attributes">
				<attribute name="groups">custom_crm_mfx.group_create_accounting_entry</attribute>
			</xpath>
			<xpath expr="//button[@name='action_create_invoice'][2]" position="attributes">
				<attribute name="groups">custom_crm_mfx.group_create_accounting_entry</attribute>
			</xpath>
		</field>
	</record>

    <record id="mfx_view_order_form" model="ir.ui.view">
		<field name="name">sale.order.form</field>
		<field name="model">sale.order</field>
		<field name="inherit_id" ref="sale.view_order_form"/>
		<field name="arch" type="xml">
			<xpath expr="//button[@id='create_invoice']" position="attributes">
				<attribute name="groups">custom_crm_mfx.group_create_accounting_entry</attribute>
			</xpath>
			<xpath expr="//button[@id='create_invoice_percentage']" position="attributes">
				<attribute name="groups">custom_crm_mfx.group_create_accounting_entry</attribute>
			</xpath>
		</field>
	</record>
</odoo>