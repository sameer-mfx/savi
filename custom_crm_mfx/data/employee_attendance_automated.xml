<odoo>

    <record id="ir_cron_automate_attendance" model="ir.cron">
        <field name="name">Automate Employee Attendance</field>
        <field name="model_id" ref="custom_crm_mfx.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.automate_employee_attendance()</field>
        <field name="interval_type">days</field>
        <field name="interval_number">1</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

</odoo>