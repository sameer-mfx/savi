<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_create_service_order_wizard_form" model="ir.ui.view">
        <field name="name">create.service.order.wizard.form</field>
        <field name="model">create.service.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Service Order">
                <sheet>
                    <group>
                        <field name="sale_order_id"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <tree editable="bottom" create="0" edit="1" delete="0">
                                    <field name="product_id" readonly="1" force_save="1"/>
                                    <field name="service_product_id"/>
                                    <field name="product_qty"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button string="Create Service Orders" type="object" name="action_create_service_order" class="btn-primary"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>