<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="incredible_external_layout">
        <!-- Multicompany -->
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>
        <t t-call="general_template.incredible_header"/>
        <div class="article o_report_layout_standard" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-out="0"/>
        </div>
        <t t-call="general_template.template_footer"/>
    </template>
    <template id="incredible_header">
            <div class="header container" t-att-style="'font-family:'+o.company_id.font_id.family+';font-size:'+str(o.company_id.font_size)+'px;'">
                <div class="row">
                    <div class="col-9">
                        <t t-if="o.company_id.invoice_logo">
                            <img t-att-src="image_data_uri(o.company_id.invoice_logo)" style="height: 100px;"/>
                        </t>
                    </div>
                    <div class="col-3" >
                        <t t-call="general_template.templates_company_details"/>
                    </div>
                </div>
                <div>
                    <p t-attf-style="border-bottom:1px solid #{theme_color}; padding:5px"/>
                </div>
            </div>
    </template>
    <template id="report_invoice_incredible_main">
        <t t-call="general_template.incredible_external_layout">
            <t t-set="o" t-value="o.with_context({'lang':o.partner_id.lang})"/>
            <t t-set="theme_color" t-value="o.company_id and o.company_id.theme_color"/>
            <t t-set="theme_text_color" t-value="o.company_id and o.company_id.theme_text_color"/>
            <t t-set="company_color" t-value="o.company_id and o.company_id.company_color"/>
            <t t-set="company_address_color" t-value="o.company_id and o.company_id.company_address_color"/>
            <t t-set="customer_color" t-value="o.company_id and o.company_id.customer_color"/>
            <t t-set="customer_address_color" t-value="o.company_id and o.company_id.customer_address_color"/>
            <t t-set="text_color" t-value="o.company_id and o.company_id.text_color"/>
            <div class="page" t-att-style="'font-family:'+o.company_id.font_id.family+';font-size:'+str(o.company_id.font_size)+'px;'">
                <div class="oe_structure"/>
                <t t-call="general_template.template_watermark"/>
                <div  width="100%">
                    <div t-att-style="'font-family:'+o.company_id.font_id.family+';font-size:'+str(o.company_id.font_size)+'px;'">
                        <div width="100%">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-8">
                                        <div  t-attf-style="color: #{o.company_id and o.company_id.theme_color or '#000000'};font-size:50px;">
                                            <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</span>
                                            <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                                            <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                                            <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                                            <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                                            <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                                        </div>
                                        <t t-call="general_template.invoice_templates_customer_details"/>
                                        <div t-attf-style="border-top:1px solid #{theme_color or '000000'};width:50%;">
                                            <t t-call="general_template.invoice_templates_customer_shipping_details"/>
                                        </div>
                                    </div>
                                    <div class="col-4" valign="top">
                                        <table class="table table-borderless" border="0" cellpadding="0" cellspacing="0" t-attf-style="color: #{o.company_id and o.company_id.theme_text_color or '#000000'};font-weight:bold; background-color: #{o.company_id and o.company_id.theme_color or '#000000'};">
                                            <tr>
                                                <td style="padding:9px 15px; font-weight:bold;">
                                                    <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</span>
                                                    <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                                                    <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                                                    <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                                                    <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                                                    <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                                                </td>
                                                <td style="text-align:right; font-weight:bold;padding:9px 15px;">
                                                    <span t-field="o.name"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td colspan="2" style="background-color:#f2f2f2; height:4px;"/>
                                            </tr>
                                            <tr t-if="o._get_invoice_date()">
                                                <td style="padding:5px 15px;">
                                                    <b>Invoice Date:</b>
                                                </td>
                                                <td style="text-align:right; padding:5px 15px;">
                                                    <span t-out="o._get_invoice_date()"/>
                                                </td>
                                            </tr>
                                            <tr t-if="o.amount_total">
                                                <td style="padding:5px 15px;">
                                                    <b>Grand Total:</b>
                                                </td>
                                                <td style="text-align:right; padding:5px 15px;">
                                                    <span t-out="o.amount_total"/>
                                                </td>
                                            </tr>
                                            <tr/>
                                            
                                            <tr t-if="o._get_invoice_due_date()">
                                                <td style="padding:5px 15px;">
                                                    <b>Due Date:</b>
                                                </td>
                                                <td style="text-align:right; padding:5px 15px;">
                                                    <span t-out="o._get_invoice_due_date()"/>
                                                </td>
                                            </tr>
                                            <tr t-if="o.source_id.name">
                                                <td style="padding:5px 15px;">
                                                    <b>Source:</b>
                                                </td>
                                                <td style="text-align:right; padding:5px 15px;">
                                                    <span t-out="o.source_id.name"/>
                                                </td>
                                            </tr>
                                            <tr t-if="o.partner_id.ref">
                                                <td style="padding:5px 15px;">
                                                    <b>Customer code:</b>
                                                </td>
                                                <td style="text-align:right; padding:5px 15px;">
                                                    <span t-out="o.partner_id.ref"/>
                                                </td>
                                            </tr>
                                            <tr t-if="o.invoice_origin">
                                                <td style="padding:5px 15px;">
                                                    <b>
                                                        <span t-if="o.move_type in ('out_invoice','out_refund')">SO:</span>
                                                        <span t-if="o.move_type in ('in_invoice', 'in_refund')">PO:</span>
                                                    </b>
                                                </td>
                                                <td style="text-align:right;padding:5px 15px;">
                                                    <span t-field="o.invoice_origin"/>
                                                </td>
                                            </tr>
                                            <tr t-if="o._get_origin_date(o.invoice_origin)">
                                                <td style="padding:5px 15px;">
                                                    <b>Order Date:</b>
                                                </td>
                                                <td style="text-align:right; padding:5px 15px;">
                                                    <span t-out="o._get_origin_date(o.invoice_origin)"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div>
                        <p t-attf-style="border-bottom:1px solid #{theme_color or '#ececec'}; padding:5px"/>
                    </div>
                    <div style="padding:5px 0px 0 0; font-weight:bold; width:100%;" >
                        <t t-call="general_template.report_invoice_order_lines"/>
                    </div>
                    <div>
                        <t t-call="general_template.invoice_subtotal_tem" />
                    </div>
                    <div t-attf-style="border-bottom:1px solid #{'#959595'}; padding:0px">
                        <t t-call="general_template.template_total_amount_word"/>
                    </div>                        
                    <div t-if="not o._compute_payments_widget_reconciled_info()">
                        <p t-att-style="'font-weight:bold; color:#000; margin-bottom:0; text-transform:capitalize; margin-top:8px; color: %s;' % (text_color)">
                                Payment Status: 
                                <span t-out="dict(o._fields['payment_state']._description_selection(o.env)).get(o.payment_state)"/>
                        </p>
                    </div>
                    <div class="pull-left" style="color: #{text_color or '#000000'}; padding-top:5px; ">
                        <t t-call="general_template.report_invoice_notes"/>
                    </div>
                    <div align="right"  style="color: #{text_color or '#000000'};">
                        <t t-call="general_template.report_invoice_signature"/>
                    </div>
                </div>
                <div class="oe_structure"/>
                <t t-call="general_template.report_invoice_barcode"/>
            </div>
        </t>
    </template>
    <template id="report_invoice_template_custom_incredible">
        <t t-call="web.html_container">
            <t t-as="o" t-foreach="docs">
                <t t-set="o" t-value="o.with_context(lang=lang)" />
                <t t-call="general_template.report_invoice_incredible_main" t-lang="lang"/>
            </t>
        </t>
    </template>
    <template id="report_invoice_incredible_main_duplicate" inherit_id="general_template.report_invoice_incredible_main" primary="True">
        <!-- <xpath expr="//div[@t-if='not o._compute_payments_widget_reconciled_info()']" position="before">
            <t t-call="general_template.report_invoice_payment_move_line"/>
        </xpath> -->
    </template>
</odoo>
