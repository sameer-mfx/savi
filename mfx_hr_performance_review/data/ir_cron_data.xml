<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron: Send review deadline reminders -->
        <record id="ir_cron_review_deadline_reminder" model="ir.cron">
            <field name="name">Performance Review: Deadline Reminders</field>
            <field name="model_id" ref="model_hr_review_cycle"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_deadline_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
