<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Review Template Form View -->
    <record id="view_review_template_form" model="ir.ui.view">
        <field name="name">hr.review.template.form</field>
        <field name="model">hr.review.template</field>
        <field name="arch" type="xml">
            <form string="Review Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Standard Employee Review"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="department_ids" widget="many2many_tags"/>
                            <field name="job_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Evaluation Criteria" name="criteria">
                            <field name="criteria_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="weight"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                            <div class="alert alert-info" role="alert">
                                <strong>Note:</strong> The total weight of all criteria must equal 100%.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Review Template List View -->
    <record id="view_review_template_list" model="ir.ui.view">
        <field name="name">hr.review.template.list</field>
        <field name="model">hr.review.template</field>
        <field name="arch" type="xml">
            <tree string="Review Templates">
                <field name="name"/>
                <field name="department_ids" widget="many2many_tags"/>
                <field name="job_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <!-- Review Template Search View -->
    <record id="view_review_template_search" model="ir.ui.view">
        <field name="name">hr.review.template.search</field>
        <field name="model">hr.review.template</field>
        <field name="arch" type="xml">
            <search string="Review Templates">
                <field name="name"/>
                <field name="department_ids"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_review_template" model="ir.actions.act_window">
        <field name="name">Review Templates</field>
        <field name="res_model">hr.review.template</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_review_template_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first review template
            </p>
            <p>
                Define evaluation criteria with weighted categories to standardize
                your performance review process.
            </p>
        </field>
    </record>

</odoo>
