<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Performance Review Form View -->
    <record id="view_performance_review_form" model="ir.ui.view">
        <field name="name">hr.performance.review.form</field>
        <field name="model">hr.performance.review</field>
        <field name="arch" type="xml">
            <form string="Performance Review">
                <header>
                    <button name="action_start_self_review" string="Send for Self-Review"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="mfx_hr_performance_review.group_performance_manager"/>
                    <button name="action_submit_self_review" string="Submit Self-Review"
                            type="object" class="btn-primary"
                            invisible="state != 'self_review'"/>
                    <button name="action_submit_manager_review" string="Submit Manager Review"
                            type="object" class="btn-primary"
                            invisible="state != 'manager_review'"
                            groups="mfx_hr_performance_review.group_performance_manager"/>
                    <button name="action_approve" string="Approve &amp; Complete"
                            type="object" class="btn-primary"
                            invisible="state != 'hr_review'"
                            groups="mfx_hr_performance_review.group_performance_hr"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"
                            groups="mfx_hr_performance_review.group_performance_hr"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,self_review,manager_review,hr_review,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="id"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="manager_id"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="cycle_id" readonly="id"/>
                            <field name="template_id"/>
                            <field name="date_review"
                                   readonly="state != 'draft'"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <!-- Rating Summary -->
                    <group string="Rating Summary" invisible="state == 'draft'">
                        <group>
                            <field name="self_rating"/>
                            <field name="manager_rating"/>
                        </group>
                        <group>
                            <field name="goal_achievement_rate" widget="progressbar"/>
                            <field name="final_rating"/>
                            <field name="final_rating_label"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Evaluation Criteria Tab -->
                        <page string="Evaluation Criteria" name="criteria">
                            <field name="rating_line_ids" nolabel="1">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="criteria_id" readonly="1"/>
                                    <field name="criteria_category" readonly="1"/>
                                    <field name="weight" readonly="1"/>
                                    <field name="self_score"
                                           readonly="parent.state not in ('self_review',)"/>
                                    <field name="self_comment"
                                           readonly="parent.state not in ('self_review',)"/>
                                    <field name="manager_score"
                                           readonly="parent.state not in ('manager_review',)"
                                           invisible="parent.state in ('draft', 'self_review')"/>
                                    <field name="manager_comment"
                                           readonly="parent.state not in ('manager_review',)"
                                           invisible="parent.state in ('draft', 'self_review')"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Self-Assessment Tab -->
                        <page string="Self-Assessment" name="self_assessment">
                            <group>
                                <field name="self_summary"
                                       placeholder="Summarize your performance during this review period..."
                                       readonly="state not in ('self_review',)"/>
                                <field name="self_strengths"
                                       placeholder="What are your key strengths?"
                                       readonly="state not in ('self_review',)"/>
                                <field name="self_improvements"
                                       placeholder="What areas would you like to improve?"
                                       readonly="state not in ('self_review',)"/>
                            </group>
                        </page>

                        <!-- Manager Assessment Tab -->
                        <page string="Manager Assessment" name="manager_assessment"
                              invisible="state in ('draft', 'self_review')">
                            <group>
                                <field name="manager_summary"
                                       placeholder="Provide your assessment of the employee's performance..."
                                       readonly="state not in ('manager_review',)"/>
                                <field name="manager_strengths"
                                       placeholder="Employee's key strengths..."
                                       readonly="state not in ('manager_review',)"/>
                                <field name="manager_improvements"
                                       placeholder="Areas for improvement..."
                                       readonly="state not in ('manager_review',)"/>
                            </group>
                        </page>

                        <!-- Goals Tab -->
                        <page string="Goals" name="goals">
                            <field name="goal_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="goal_type"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="deadline"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'in_progress'"
                                           decoration-success="state == 'achieved'"
                                           decoration-danger="state == 'not_achieved'"/>
                                </tree>
                            </field>
                        </page>

                        <!-- HR Comments Tab -->
                        <page string="HR Comments" name="hr_comments"
                              groups="mfx_hr_performance_review.group_performance_hr">
                            <group>
                                <field name="hr_comments"
                                       placeholder="HR notes and final comments..."
                                       readonly="state not in ('hr_review',)"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Performance Review List View -->
    <record id="view_performance_review_list" model="ir.ui.view">
        <field name="name">hr.performance.review.list</field>
        <field name="model">hr.performance.review</field>
        <field name="arch" type="xml">
            <tree string="Performance Reviews"
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('self_review', 'manager_review')"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="manager_id" widget="many2one_avatar_employee"/>
                <field name="cycle_id"/>
                <field name="self_rating" optional="show"/>
                <field name="manager_rating" optional="show"/>
                <field name="final_rating" decoration-success="final_rating >= 3.5"
                       decoration-warning="final_rating >= 2.5 and final_rating &lt; 3.5"
                       decoration-danger="final_rating > 0 and final_rating &lt; 2.5"/>
                <field name="final_rating_label" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('self_review', 'manager_review', 'hr_review')"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Performance Review Kanban View -->
    <record id="view_performance_review_kanban" model="ir.ui.view">
        <field name="name">hr.performance.review.kanban</field>
        <field name="model">hr.performance.review</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="manager_id"/>
                <field name="final_rating"/>
                <field name="final_rating_label"/>
                <field name="state"/>
                <field name="self_rating"/>
                <field name="manager_rating"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb-0">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="employee_id"/>
                                        </strong>
                                    </div>
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <span class="text-muted">Department: </span>
                                        <field name="department_id"/>
                                    </div>
                                    <div>
                                        <span class="text-muted">Manager: </span>
                                        <field name="manager_id"/>
                                    </div>
                                    <div t-if="record.final_rating.raw_value > 0">
                                        <span class="text-muted">Rating: </span>
                                        <strong>
                                            <field name="final_rating"/>
                                            / 5.0
                                        </strong>
                                        <span class="ms-1 badge rounded-pill bg-info">
                                            <field name="final_rating_label"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Performance Review Search View -->
    <record id="view_performance_review_search" model="ir.ui.view">
        <field name="name">hr.performance.review.search</field>
        <field name="model">hr.performance.review</field>
        <field name="arch" type="xml">
            <search string="Performance Reviews">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="manager_id"/>
                <field name="cycle_id"/>
                <separator/>
                <filter string="My Reviews" name="filter_my"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="My Team" name="filter_my_team"
                        domain="[('manager_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Self-Review" name="filter_self_review"
                        domain="[('state', '=', 'self_review')]"/>
                <filter string="Manager Review" name="filter_manager_review"
                        domain="[('state', '=', 'manager_review')]"/>
                <filter string="HR Review" name="filter_hr_review"
                        domain="[('state', '=', 'hr_review')]"/>
                <filter string="Completed" name="filter_done"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Outstanding" name="filter_outstanding"
                        domain="[('final_rating', '>=', 4.5)]"/>
                <filter string="Exceeds Expectations" name="filter_exceeds"
                        domain="[('final_rating', '>=', 3.5), ('final_rating', '&lt;', 4.5)]"/>
                <filter string="Needs Improvement" name="filter_needs_improvement"
                        domain="[('final_rating', '&gt;', 0), ('final_rating', '&lt;', 2.5)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_department"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Manager" name="group_manager"
                            context="{'group_by': 'manager_id'}"/>
                    <filter string="Review Cycle" name="group_cycle"
                            context="{'group_by': 'cycle_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Performance Level" name="group_rating"
                            context="{'group_by': 'final_rating_label'}"/>
                    <filter string="Job Position" name="group_job"
                            context="{'group_by': 'job_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_performance_review" model="ir.actions.act_window">
        <field name="name">Performance Reviews</field>
        <field name="res_model">hr.performance.review</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_performance_review_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No performance reviews yet
            </p>
            <p>
                Create a review cycle and generate reviews for employees, or
                create individual reviews directly.
            </p>
        </field>
    </record>

    <!-- Action: My Reviews -->
    <record id="action_my_reviews" model="ir.actions.act_window">
        <field name="name">My Reviews</field>
        <field name="res_model">hr.performance.review</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_performance_review_search"/>
        <field name="context">{'search_default_filter_my': 1}</field>
    </record>

    <!-- Action: My Team Reviews -->
    <record id="action_team_reviews" model="ir.actions.act_window">
        <field name="name">Team Reviews</field>
        <field name="res_model">hr.performance.review</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_performance_review_search"/>
        <field name="context">{'search_default_filter_my_team': 1}</field>
    </record>

</odoo>
