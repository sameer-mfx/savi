<odoo>
    <record id="seq_project_daily_report" model="ir.sequence">
        <field name="name">SAVI Project Daily Report</field>
        <field name="code">x_savi.project.daily.report</field>
        <field name="prefix">PDR/</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_project_closure" model="ir.sequence">
        <field name="name">SAVI Project Closure</field>
        <field name="code">x_savi.project.closure</field>
        <field name="prefix">PCL/</field>
        <field name="padding">5</field>
    </record>

    <record id="view_x_savi_project_daily_report_tree" model="ir.ui.view">
        <field name="name">x_savi.project.daily.report.tree</field>
        <field name="model">x_savi.project.daily.report</field>
        <field name="arch" type="xml">
            <tree decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="report_date"/>
                <field name="period"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="partner_id"/>
                <field name="responsible_id"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_x_savi_project_daily_report_form" model="ir.ui.view">
        <field name="name">x_savi.project.daily.report.form</field>
        <field name="model">x_savi.project.daily.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="project.group_project_manager"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('submitted', 'approved')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="task_id"/>
                            <field name="partner_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="report_date"/>
                            <field name="period"/>
                            <field name="responsible_id"/>
                            <field name="engineer_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Report">
                            <field name="work_done"/>
                            <field name="blockers"/>
                            <field name="material_used"/>
                            <field name="next_plan"/>
                        </page>
                        <page string="Attachments">
                            <group>
                                <field name="site_image_ids" widget="many2many_binary"/>
                                <field name="document_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_x_savi_project_closure_tree" model="ir.ui.view">
        <field name="name">x_savi.project.closure.tree</field>
        <field name="model">x_savi.project.closure</field>
        <field name="arch" type="xml">
            <tree decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="completion_date"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="revenue_amount"/>
                <field name="expense_amount"/>
                <field name="profit_amount"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_x_savi_project_closure_form" model="ir.ui.view">
        <field name="name">x_savi.project.closure.form</field>
        <field name="model">x_savi.project.closure</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="project.group_project_manager"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('submitted', 'approved')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="completion_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="revenue_amount"/>
                            <field name="expense_amount"/>
                            <field name="profit_amount"/>
                        </group>
                    </group>
                    <group string="Closure Checklist">
                        <field name="final_testing_done"/>
                        <field name="handover_done"/>
                        <field name="completion_certificate_received"/>
                        <field name="testimonial_received"/>
                        <field name="website_photos_collected"/>
                    </group>
                    <notebook>
                        <page string="Audit">
                            <field name="customer_feedback"/>
                            <field name="audit_notes"/>
                        </page>
                        <page string="Attachments">
                            <group>
                                <field name="handover_document_ids" widget="many2many_binary"/>
                                <field name="completion_photo_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_x_savi_project_daily_report" model="ir.actions.act_window">
        <field name="name">Daily Site Reports</field>
        <field name="res_model">x_savi.project.daily.report</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_x_savi_project_closure" model="ir.actions.act_window">
        <field name="name">Project Closures</field>
        <field name="res_model">x_savi.project.closure</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_savi_project_execution_root" name="Execution" parent="project.menu_main_pm" sequence="40"/>
    <menuitem id="menu_savi_project_daily_report" name="Daily Site Reports" parent="menu_savi_project_execution_root" action="action_x_savi_project_daily_report" sequence="10"/>
    <menuitem id="menu_savi_project_closure" name="Project Closures" parent="menu_savi_project_execution_root" action="action_x_savi_project_closure" sequence="20"/>
</odoo>
