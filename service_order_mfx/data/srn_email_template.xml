<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Customer Satisfaction Survey - SRN -->
        <record id="email_template_srn_satisfaction" model="mail.template">
            <field name="name">SRN - Customer Satisfaction Survey</field>
            <field name="model_id" ref="model_srn"/>
            <field name="subject">Your feedback on Service Visit {{ object.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ object.customer_id.email }}</field>
            <field name="description">Sent after an SRN is approved/closed, asking the customer to rate the visit.</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-size: 13px;">
                    <p>Dear <t t-out="object.customer_id.name or 'Valued Customer'"/>,</p>

                    <p>We hope our recent service visit under reference <strong><t t-out="object.name"/></strong><t t-if="object.date_confirm"> (completed on <t t-out="format_date(object.date_confirm, 'dd MMM yyyy')"/>)</t> addressed your requirement fully.</p>

                    <p>Your honest feedback helps us maintain and improve the quality of service our engineers deliver.</p>

                    <p><strong>Visit summary:</strong></p>
                    <ul>
                        <li><strong>SRN Reference:</strong> <t t-out="object.name"/></li>
                        <li t-if="object.customer_ref"><strong>Your Reference:</strong> <t t-out="object.customer_ref"/></li>
                        <li t-if="object.date_order"><strong>Visit Date:</strong> <t t-out="format_datetime(object.date_order, tz=user.tz, dt_format='dd MMM yyyy HH:mm')"/></li>
                        <li t-if="object.user_id"><strong>Responsible:</strong> <t t-out="object.user_id.name"/></li>
                    </ul>

                    <div t-if="object.srn_line_ids">
                        <p><strong>Services performed during this visit:</strong></p>
                        <table border="1" cellpadding="6" cellspacing="0" style="border-collapse: collapse; width: 100%; font-size: 12px;">
                            <thead style="background-color: #f4f4f4;">
                                <tr>
                                    <th style="text-align: left;">#</th>
                                    <th style="text-align: left;">Product</th>
                                    <th style="text-align: left;">Service</th>
                                    <th style="text-align: left;">Description</th>
                                    <th style="text-align: right;">Qty</th>
                                    <th style="text-align: left;">Serial / Lot</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="object.srn_line_ids" t-as="line">
                                    <td><t t-out="line_index + 1"/></td>
                                    <td><t t-out="line.product_id.display_name or ''"/></td>
                                    <td><t t-out="line.service_product_id.display_name or ''"/></td>
                                    <td><t t-out="line.description or ''"/></td>
                                    <td style="text-align: right;"><t t-out="'{:g}'.format(line.product_qty or 0)"/></td>
                                    <td><t t-out="', '.join(line.product_identification_ids.mapped('name')) or '-'"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <p style="margin-top: 16px;"><strong>You can share your feedback in either way - whichever is easier for you:</strong></p>

                    <p style="text-align: center; margin: 16px 0;">
                        <a href="https://forms.gle/tZEUDXkNVUW9GEiD9"
                           style="background-color: #00A09D; color: #ffffff; padding: 12px 24px; text-decoration: none; border-radius: 4px; font-weight: bold; display: inline-block;">
                            Fill the Quick Feedback Form (1 minute)
                        </a>
                    </p>

                    <p style="text-align: center; color: #888;">- or -</p>

                    <p>Simply <strong>reply to this email</strong> with the following:</p>
                    <ol>
                        <li>Overall satisfaction with this visit - rate <strong>1 (Poor)</strong> to <strong>5 (Excellent)</strong>.</li>
                        <li>Was the engineer able to resolve your issue?</li>
                        <li>Was the visit timely?</li>
                        <li>Any suggestions or concerns?</li>
                    </ol>

                    <p>Thank you for your continued trust.</p>

                    <p>Warm regards,<br/>
                    <t t-out="object.user_id.name or 'Customer Success Team'"/><br/>
                    <t t-out="object.company_id.name"/>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
            <field name="lang">{{ object.customer_id.lang }}</field>
        </record>

    </data>
</odoo>
