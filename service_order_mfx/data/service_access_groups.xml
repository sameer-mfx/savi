<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Module category for better UI grouping -->
        <record id="service_order_category_user_manager" model="ir.module.category">
            <field name="name">Service Order</field>
            <field name="description">Service Order group for users and managers</field>
        </record>

        <record id="service_order_group_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="service_order_category_user_manager"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="service_order_group_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="service_order_category_user_manager"/>
            <field name="implied_ids" eval="[(4, ref('service_order_mfx.service_order_group_user'))]"/>
        </record>

        <!-- Add Service Order Manager group to the Admin user -->
        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('service_order_mfx.service_order_group_manager'))]"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('service_order_mfx.service_order_group_manager'))]"/>
        </record>
    </data>
</odoo>