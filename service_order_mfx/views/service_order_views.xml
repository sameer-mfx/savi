<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- IR Rule to control user control based on the company assosciated to him -->
    <record id="service_order_rule_company" model="ir.rule">
        <field name="name">Service Order: company rule</field>
        <field name="model_id" ref="model_service_order"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- This action will be called when Service Order menu item was clicked -->
    <record id="action_service_order" model="ir.actions.act_window">
        <field name="name">Service Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">service.order</field>
        <field name="view_mode">tree,form</field>
        <field name="binding_view_types">form</field>
        <field name="context">{'search_default_group_by_customer_id': 1}</field>
        <field name="domain">[('state', '!=', 'draft')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a request for Order
            </p>
            <p>
                The Order contains the history of the discussion
                you had with your customer.
            </p>
        </field>
    </record>
    
    <!-- This action will be called when Service Quotation menu item was clicked -->
    <record id="action_service_quotation" model="ir.actions.act_window">
        <field name="name">Requests For Service Quotation</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">service.order</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'draft')]</field>
        <field name="context">{'search_default_group_by_customer_id': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a request for quotation
            </p>
            <p>
                The quotation contains the history of the discussion
                you had with your customer.
            </p>
        </field>
    </record>

    <!-- Service Order Form view with service order lines -->
    <record id="service_order_form" model="ir.ui.view">
        <field name="name">service.order.form</field>
        <field name="model">service.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Service Order">
                <header>
                    <button name="sso_action_approve" type="object" class="oe_highlight" string="Send for Approval" invisible="state not in ('draft')" groups="service_order_mfx.service_order_group_manager"/>
                    <button name="sso_action_confirm" type="object" string="Approve" invisible="state not in ('to_approve')" class="oe_highlight" groups="service_order_mfx.service_order_group_manager"/>
                    <button name="sso_create_srn" type="object" string="Create SRN" invisible="not (state == 'approved' and not srn_count and not is_amc)" class="oe_highlight" groups="service_order_mfx.service_order_group_manager"/>
                    <button name="sso_action_draft" type="object" string="Reset to Draft" invisible="state != 'cancel'" groups="service_order_mfx.service_order_group_manager"/>
                    <button name="sso_action_cancel" string="Cancel" type="object" class="btn btn-danger" invisible="state in ('approved', 'cancel')" groups="service_order_mfx.service_order_group_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved"/>
                    <field name="srn_count" invisible="1"/>
                </header>
                <sheet>
                    <div class="pull-left">
                        <label for="name" class="oe_edit_only oe_inline" />
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1" force_save="1"/>
                            <field name="assigned_to" required="state == 'to_approve'" readonly="(state != 'to_approve') and (not is_amc)" invisible="state in ('draft', 'cancel')" groups="service_order_mfx.service_order_group_manager" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="customer_id" required="1" readonly="state != 'draft'" domain="[('user_ids', '=', False)]" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="customer_ref" readonly="state != 'draft'"/>
                            <field name="visit_date" readonly="(state != 'to_approve') and (not is_amc)" invisible="state in ('draft', 'cancel') or not srn_count or not is_amc" groups="service_order_mfx.service_order_group_manager"/>
                        </group>
                        <group>
                            <field name="date_order" readonly="1" force_save="1" string="Order Date" invisible="not date_order or date_approve"/>
                            <field name="date_approve" readonly="1" force_save="1" string="Approve Date" invisible="not date_approve"/>
                            <field name="currency_id" readonly="1" force_save="1"/>
                            <label for="company_id"/>
                            <div id="company_and_recurring_task" class="d-inline-flex w-100">
                                <field name="company_id" readonly="1" force_save="1"/>
                                <field name="is_amc" nolabel="1" class="ms-0" style="width: fit-content;" widget="boolean_icon" options="{'icon': 'fa-repeat'}" groups="service_order_mfx.service_order_group_manager" invisible="state in ('approved', 'cancel')"/>
                            </div>
                            <field name="amc_start_date" required="is_amc" invisible="not is_amc" groups="service_order_mfx.service_order_group_manager"/>
                            <label for="repeat_interval" groups="service_order_mfx.service_order_group_manager" invisible="not amc_start_date"/>
                            <div invisible="not amc_start_date" class="d-flex" groups="service_order_mfx.service_order_group_manager">
                                <field name="repeat_interval" required="amc_start_date" class="me-2" style="max-width: 2rem !important;"/>
                                <field name="repeat_unit" required="amc_start_date" class="me-2" style="max-width: 4rem !important;"/>
                                <field name="repeat_type" required="amc_start_date" class="me-2" style="max-width: 15rem !important;"/>
                                <field name="repeat_until" invisible="repeat_type != 'until'" required="repeat_type == 'until'" class="me-2"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Services">
                            <field name="order_line_ids" readonly="state not in ('draft', 'to_approve')">
                                <tree string="Services" editable="bottom" decoration-mute="parent.state == 'cancel'" create="1" edit="1" delete="1">
                                    <field name="product_id" required="1" string="Product" domain="[('detailed_type', '=', 'product')]" readonly="parent.state not in ('draft', 'to_approve')" options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="service_product_id" required="1" string="Service" domain="[('detailed_type', '=', 'service')]" readonly="parent.state not in ('draft', 'to_approve')" options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="quantity" readonly="parent.state not in ('draft', 'to_approve')"/>
                                    <field name="description" readonly="1" force_save="1"/>
                                    <field name="uom_id" readonly="1" force_save="1"/>
                                    <field name="is_tracked" column_invisible="1"/>
                                    <field name="product_identification_ids" widget="many2many_tags" context="{'default_product_id': product_id}" domain="[('product_id', '=', product_id)]" required="is_tracked" readonly="parent.state not in ('draft', 'to_approve') or not is_tracked"/>
                                    <field name="unit_price" readonly="parent.state not in ('draft', 'to_approve')"/>
                                    <field name="tax_ids" widget="many2many_tags" string="Taxes" minWidth="10%" readonly="parent.state not in ('draft', 'to_approve')"  domain="[('type_tax_use', '=', 'sale')]"/>
                                    <field name="sub_total" readonly="1" force_save="1"/>
                                    <field name="location" required="1" readonly="parent.state not in ('draft', 'to_approve')"/>
                                    <field name="remarks" readonly="parent.state not in ('draft', 'to_approve')" optional="show"/>
                                    <field name="under_warranty" column_invisible="parent.state in ('draft', 'cancel')" optional="show"/>
                                </tree>
                            </field>
                        </page>
                        <group>
                            <field name="notes" class="oe_inline" placeholder="Remarks" />
                            <field name="terms_and_conditions" class="oe_inline" placeholder="Terms and Conditions" />
                        </group>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user" />
                    <field name="activity_ids" />
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Service Order search view -->
    <record id="view_service_order_search" model="ir.ui.view">
        <field name="name">service.order.search.view</field>
        <field name="model">service.order</field>
        <field name="arch" type="xml">
            <search string="Customer">
                <group expand="0" string="Group By">
                    <filter name="group_by_customer_id" string="Customer" domain="[]"  context="{'group_by':'customer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Service Order tree view -->
    <record id="service_order_tree" model="ir.ui.view">
        <field name="name">service.order.tree</field>
        <field name="model">service.order</field>
        <field name="arch" type="xml">
            <tree string="Service Orders" decoration-muted="state == 'cancel'" create="true" edit="true" sample="1" default_order='name DESC' >
                <field name="is_amc" optional="hide"/>
                <field name="name" string="Reference"/>
                <field name="customer_id"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="date_order"/>
                <field name="state" widget="badge" decoration-danger="state =='cancel'" decoration-info="state == 'to_approve'" decoration-muted="state == 'draft'" decoration-success="state == 'approved'"/>
            </tree>
        </field>
    </record>

    <record id="product_normal_action_puchased" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,tree,form,activity</field>
        <field name="context">{"search_default_filter_to_purchase":1, "purchase_product_template": 1}</field>
        <field name="search_view_id" ref="product.product_template_search_view"/>
        <field name="view_id" eval="False"/>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            No product found. Let's create one!
          </p><p>
            You must define a product for everything you sell or purchase,
            whether it's a storable product, a consumable or a service.
          </p>
        </field>
    </record>

    <!-- Top menu item -->
    <menuitem name="Service Orders"
              id="menu_service_root"
              web_icon="service_order_mfx,static/description/icon.png"
              groups="service_order_mfx.service_order_group_user"
              sequence="136"/>

    <menuitem id="menu_service_management"
              name="Orders"
              parent="menu_service_root"
              sequence="1"/>

    <!-- Service Quotation menu item -->
    <menuitem id="menu_service_quotation"
              name="Service Quotation"
              parent="menu_service_management"
              action="action_service_quotation"
              sequence="1"/>

    <!-- Service Order menu item -->
    <menuitem id="menu_service_order"
              name="Service Orders"
              parent="menu_service_management"
              action="action_service_order"
              sequence="2"/>

    <menuitem id="menu_products"
              name="Products"
              parent="menu_service_root"
              sequence="2"/>

    <!-- Product menu item -->
    <menuitem id="menu_product"
              name="Products"
              parent="menu_products"
              action="product_normal_action_puchased"
              sequence="1"/>

</odoo>