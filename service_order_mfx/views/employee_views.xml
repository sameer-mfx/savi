<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="emplyee_view_service_order_inherit" model="ir.ui.view">
        <field name="name">employee.view.service.order.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='coach_id']" position="after">
                <label for="performance_rating">Performance Rating</label>
                <div id="employeee_performance_rating" class="d-inline-flex">
                    <field name="performance_rating"/>⭐
                </div>
            </xpath>
        </field>
    </record>
</odoo>