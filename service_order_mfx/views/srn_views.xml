<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- IR Rule to control user control based on the company assosciated to him -->
    <record id="srn_rule_company" model="ir.rule">
        <field name="name">SRN: company rule</field>
        <field name="model_id" ref="model_srn"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- This action will be called when the smart button is clicked -->
    <record model="ir.actions.act_window" id="action_srn_list">
        <field name="name">SRN</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">srn</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Added a button for creating SRN -->
    <record id="view_service_order_inherit" model="ir.ui.view">
        <field name="name">Service Order Inherit</field>
        <field name="model">service.order</field>
        <field name="inherit_id" ref="service_order_mfx.service_order_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//sheet/div[hasclass('pull-left')]" position="before">
                    <div class="oe_button_box" name="button_box">
                        <button name="spo_button_show_srns" type="object" class="oe_stat_button" icon="fa-list-alt" invisible="srn_count == 0">
                            <field name="srn_count" widget="statinfo" string="SRN"/>
                        </button>
                    </div>
                </xpath>
<!--                <xpath expr="//header" position="inside">-->
<!--                    <button type="object" name="test_crn" string="Test Cron"/>-->
<!--                </xpath>-->
            </data>
        </field>
    </record>

    <!-- SRN search view -->
    <record id="view_srn_search" model="ir.ui.view">
        <field name="name">srn.search.view</field>
        <field name="model">srn</field>
        <field name="arch" type="xml">
            <search string="Customer">
                <filter name="my_srns" string="My SRNs" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="My Activities" name="activities_my"
                    domain="[('activity_ids.user_id', '=', uid)]"/>
                <filter string="Late Activities" name="activities_overdue"
                    domain="[('activity_ids.date_deadline', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Today Activities" name="activities_today"
                    domain="[('activity_ids.date_deadline', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Future Activities" name="activities_upcoming_all"
                    domain="[('activity_ids.date_deadline', '&gt;', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_customer_id" string="Customer" domain="[]" context="{'group_by':'customer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- SRN Calendar view -->
    <record id="view_srn_calendar" model="ir.ui.view">
        <field name="name">srn.calendar</field>
        <field name="model">srn</field>
        <field name="arch" type="xml">
            <calendar string="SRNs Calendar" date_start="date_order" color="calendar_color" mode="month" create="0" delete="0">
                <field name="display_name" color="calendar_color" invisible="1"/>
                <field name="user_id" filters="1" invisible="1"/>
            </calendar>
        </field>
    </record>

    <!--SRN Form view with SRN Lines-->
    <record id="srn_form_view" model="ir.ui.view">
        <field name="name">srn.form</field>
        <field name="model">srn</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="srn_button_approve" type="object" invisible="state != 'draft'" string="Approve" class="oe_highlight" groups="service_order_mfx.service_order_group_manager"/>
                    <button name="action_send_satisfaction_email" type="object" string="Send Satisfaction Survey" class="btn-primary" invisible="state != 'done' or satisfaction_email_sent"/>
                    <button name="action_send_satisfaction_email" type="object" string="Resend Satisfaction Survey" invisible="state != 'done' or not satisfaction_email_sent"/>
                    <field name="satisfaction_email_sent" invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done" readonly="1"/>
                </header>
                <div class="alert alert-info text-center" role="alert" invisible="not satisfaction_email_sent">
                    <i class="fa fa-envelope-o"/>
                    Customer satisfaction survey was sent on
                    <field name="satisfaction_email_sent_date" readonly="1" nolabel="1" class="oe_inline"/>
                    by
                    <field name="satisfaction_email_sent_by" readonly="1" nolabel="1" class="oe_inline"/>.
                </div>
                <sheet>
                    <div class="pull-left">
                        <label for="name" class="oe_edit_only oe_inline"/>
                        <h1>
                            <field name="name" readonly="1" force_save="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="assigned_by" readonly="1" force_save="1"/>
                            <field name="user_id" readonly="1" force_save="1"/>
                            <field name="customer_id" readonly="1" force_save="1"/>
                            <field name="customer_ref" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="date_order" readonly="1" force_save="1" invisible="not date_order or date_confirm"/>
                            <field name="date_confirm" readonly="1" force_save="1" invisible="not date_confirm"/>
                            <field name="deadline" readonly="state == 'done'" required="state in ('draft', 'waiting')" invisible="state == 'cancel'"/>
                            <field name="company_id" readonly="1" force_save="1"/>
                            <field name="service_order_ids" readonly="1" force_save="1" widget="many2many_tags"/>
                            <field name="performance_rating" widget="priority" invisible="state != 'done'" readonly="performance_rating != '0'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Services on Products">
                            <field name="srn_line_ids">
                                <tree editable="bottom" decoration-muted="state == 'cancel'" create="0" edit="1" delete="0">
                                    <field name="product_id" readonly="1" force_save="1"/>
                                    <field name="service_product_id" readonly="1" force_save="1"/>
                                    <field name="description" readonly="1" force_save="1"/>
                                    <field name="product_qty" readonly="1" force_save="1"/>
                                    <field name="product_identification_ids" widget="many2many_tags" readonly="1" force_save="1" optional="hide"/>
                                    <field name="price" readonly="1" force_save="1"/>
                                    <field name="tax_ids" widget="many2many_tags" readonly="1" force_save="1"/>
                                    <field name="service_order_line_id" column_invisible="1"/>
                                    <field name="state" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <div>
                        <label for="note"/>
                        <field name="note" readonly="state != 'draft'"/>
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- SRN tree view -->
    <record id="srn_tree_view" model="ir.ui.view">
        <field name="name">srn.tree</field>
        <field name="model">srn</field>
        <field name="arch" type="xml">
            <tree string="SRN" create="0" edit="1" delete="0" sample="1">
                <field name="name" string="Name"/>
                <field name="customer_id" string="Customer"/>
                <field name="assigned_by" string="Assigned By"/>
                <field name="user_id" string="Responsible"/>
                <field name="date_confirm" string="Confirm Date"/>
                <field name="company_id"/>
                <field name="state" widget="badge" decoration-danger="state =='cancel'" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- Action to show Pending SRNs -->
    <record id="action_show_pending_srns" model="ir.actions.act_window">
        <field name="name">Pending SRNs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">srn</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="views" eval="[(ref('view_srn_calendar'), 'calendar'), (ref('srn_tree_view'), 'tree'), (ref('srn_form_view'), 'form')]"/>
        <field name="domain">[('state', '=', 'draft')]</field>
        <field name="context">{'search_default_group_by_customer_id': 1, 'search_default_my_srns': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create SRN by receiving any Service Order.
            </p>
        </field>
    </record>

    <!-- Action to show Completed SRNs -->
    <record id="action_show_completed_srns" model="ir.actions.act_window">
        <field name="name">Completed SRNs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">srn</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="views" eval="[(ref('view_srn_calendar'), 'calendar'), (ref('srn_tree_view'), 'tree'), (ref('srn_form_view'), 'form')]"/>
        <field name="domain">[('state', '=', 'done')]</field>
        <field name="context">{'search_default_group_by_customer_id': 1, 'search_default_my_srns': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create SRN by receiving any Service Order.
            </p>
        </field>
    </record>

    <menuitem
          id="srn_menu_id"
          parent="service_order_mfx.menu_service_root"
          name="SRN"
          sequence="3"/>

    <!-- Pending SRN menu item -->
    <menuitem
          id="view_pending_srns_menu_id"
          parent="srn_menu_id"
          name="Pending SRN's"
          sequence="1"
          action="action_show_pending_srns" />

    <!-- Done SRN menu item -->
    <menuitem
          id="view_done_srns_menu_id"
          parent="srn_menu_id"
          name="Done SRN's"
          sequence="2"
          action="action_show_completed_srns" />

</odoo>