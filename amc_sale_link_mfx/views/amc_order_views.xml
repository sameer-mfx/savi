<odoo>

    <!-- Smart button action to show quotations -->
    <record id="action_sale_orders_from_amc" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('amc_id','=',active_id)]</field>
    </record>

    <!-- Extend AMC Order Form to add Quotation Button + Smart Button -->
    <record id="amc_order_form_inherit_sale_link" model="ir.ui.view">
        <field name="name">amc.order.form.inherit.sale.link</field>
        <field name="model">amc.order</field>
        <field name="inherit_id" ref="amc_mfx.amc_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="sale_order_id" invisible="1"/>
                <button name="action_create_quotation" type="object" string="Create Quotation" invisible="sale_order_id or state == 'expired'" class="oe_highlight"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button type="action" name="amc_sale_link_mfx.action_sale_orders_from_amc" class="oe_stat_button" icon="fa-file-text-o" invisible="not sale_order_id">
                        <field name="sale_order_id" widget="statinfo" string="Quotations"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

</odoo>