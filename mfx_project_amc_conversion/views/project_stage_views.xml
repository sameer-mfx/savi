<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="project_stage_views_inherit_savi" model="ir.ui.view">
        <field name="name">Project Stage Views Inherit Savi</field>
        <field name="model">project.project.stage</field>
        <field name="inherit_id" ref="project.project_project_stage_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fold']" position="after">
                <field name="is_final_stage" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="project_project_stage_view_form_inherit_projects_management" model="ir.ui.view">
        <field name="name">project.project.stage.view.form.inherit.project.management</field>
        <field name="model">project.project.stage</field>
        <field name="inherit_id" ref="project.project_project_stage_view_form"/>
        <field name="arch" type="xml">
            <field name="fold" position="after">
                <field name="is_final_stage"/>
            </field>
        </field>
    </record>

</odoo>