<odoo>
    <record id="view_x_savi_service_repair_tree" model="ir.ui.view">
        <field name="name">x_savi.service.repair.tree</field>
        <field name="model">x_savi.service.repair</field>
        <field name="arch" type="xml">
            <tree decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="service_order_id"/>
                <field name="repair_type"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="assigned_to"/>
                <field name="estimated_amount"/>
                <field name="advance_status"/>
                <field name="customer_approval_status"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_x_savi_service_repair_form" model="ir.ui.view">
        <field name="name">x_savi.service.repair.form</field>
        <field name="model">x_savi.service.repair</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start_inspection" string="Start Inspection" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_send_estimate" string="Send Estimate" type="object" class="oe_highlight" invisible="state != 'inspection'"/>
                    <button name="action_customer_approve" string="Customer Approved" type="object" class="oe_highlight" invisible="state != 'estimate'"/>
                    <button name="action_start_repair" string="Start Repair" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_done" string="Mark Done" type="object" class="oe_highlight" invisible="state != 'repair'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('inspection', 'estimate', 'approved')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,inspection,estimate,approved,repair,done"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="service_order_id"/>
                            <field name="helpdesk_ticket_id"/>
                            <field name="customer_id"/>
                            <field name="customer_ref"/>
                            <field name="assigned_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="repair_type"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="estimated_amount"/>
                            <field name="advance_amount"/>
                            <field name="advance_status"/>
                            <field name="customer_approval_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Repair Details">
                            <field name="issue_description"/>
                            <field name="inspection_result"/>
                            <field name="solution_description"/>
                            <field name="new_product_discussion"/>
                            <field name="amc_discussion"/>
                        </page>
                        <page string="Attachments">
                            <group>
                                <field name="issue_photo_ids" widget="many2many_binary"/>
                                <field name="solution_photo_ids" widget="many2many_binary"/>
                                <field name="document_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_x_savi_service_repair" model="ir.actions.act_window">
        <field name="name">Repair Cases</field>
        <field name="res_model">x_savi.service.repair</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_savi_service_repair" name="Repair Cases" parent="service_order_mfx.menu_service_management" action="action_x_savi_service_repair" sequence="3"/>
</odoo>
