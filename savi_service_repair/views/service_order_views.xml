<odoo>
    <record id="service_order_form_inherit_savi_repair" model="ir.ui.view">
        <field name="name">service.order.form.inherit.savi.repair</field>
        <field name="model">service.order</field>
        <field name="inherit_id" ref="service_order_mfx.service_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Repair Cases" invisible="not savi_repair_ids">
                    <field name="savi_repair_ids" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="repair_type"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="state" widget="badge"/>
                        </tree>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
